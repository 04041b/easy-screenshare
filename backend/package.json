{
  "name": "screenshare-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create screenshare-signals",
    "db:migrate:local": "wrangler d1 execute screenshare-signals --local --file=schema.sql",
